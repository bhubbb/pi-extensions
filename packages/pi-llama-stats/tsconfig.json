{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": ".",
    "noEmit": true,
    "types": ["@earendil-works/pi-coding-agent", "node"]
  },
  "include": ["src/**/*.ts"],  // tests are validated by `bun test`, not tsc (bun:test types not in node_modules)
  "exclude": ["node_modules", "dist"]
}
