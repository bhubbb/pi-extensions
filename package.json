{
  "name": "pi-advisor-ext",
  "version": "0.3.0",
  "description": "Pi agent advisor extension with configurable context policy",
  "type": "module",
  "private": false,
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "extension"
  ],
  "license": "EUPL-1.2",
  "author": "bhubbb",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bhubbb/pi-extensions.git"
  },
  "bugs": {
    "url": "https://github.com/bhubbb/pi-extensions/issues"
  },
  "homepage": "https://github.com/bhubbb/pi-extensions",
  "files": [
    "packages/pi-advisor"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.80.2",
    "@earendil-works/pi-coding-agent": ">=0.80.2",
    "@earendil-works/pi-tui": ">=0.80.2"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.80.2",
    "@earendil-works/pi-coding-agent": "^0.80.2",
    "@earendil-works/pi-tui": "^0.80.2",
    "@types/bun": "^1.1.0",
    "@types/node": "^20.0.0",
    "typebox": "^1.3.6",
    "typescript": "^5.0.0"
  },
  "pi": {
    "extensions": [
      "./packages/pi-advisor/advisor.ts",
      "./packages/pi-todo/src/index.ts"
    ]
  },
  "scripts": {
    "test": "bun test",
    "typecheck": "bun run typecheck:advisor && bun run typecheck:llama && bun run typecheck:llama-stats && bun run typecheck:pi-todo",
    "typecheck:advisor": "tsc -p packages/pi-advisor/tsconfig.json",
    "typecheck:llama": "tsc -p packages/pi-llama/tsconfig.json",
    "typecheck:llama-stats": "tsc -p packages/pi-llama-stats/tsconfig.json",
    "typecheck:pi-todo": "tsc -p packages/pi-todo/tsconfig.json"
  }
}